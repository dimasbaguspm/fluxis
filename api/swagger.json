                        "schema": {
                            "$ref": "#/definitions/domain.OrganisationMemberUpdateModel"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
